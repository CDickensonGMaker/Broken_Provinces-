[sub_resource type="GDScript" id="GDScript_false_wall"]
script/source = "## false_wall.gd - Destructible false wall hiding secret rooms
extends StaticBody3D

## Emitted when the wall is revealed/destroyed
signal revealed

## Whether this wall has been revealed
var is_revealed: bool = false


## Reveal the hidden passage (destroys this wall)
func reveal() -> void:
	if is_revealed:
		return

	is_revealed = true
	emit_signal(\"revealed\")

	# Play reveal effect (optional)
	_play_reveal_effect()

	# Remove the wall
	queue_free()


## Called when player interacts or attacks the wall
func _on_damaged() -> void:
	reveal()


func _play_reveal_effect() -> void:
	# TODO: Add particle effect for wall crumbling
	# TODO: Play sound effect
	pass
"

