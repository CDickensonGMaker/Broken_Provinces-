[gd_scene load_steps=2 format=3 uid="uid://dungeon_test_scene"]

[sub_resource type="GDScript" id="GDScript_test"]
script/source = "## dungeon_test_scene.gd - Test scene for dungeon generation
extends Node3D

@export var test_seed: int = 12345
@export var max_rooms: int = 20
@export var auto_generate: bool = true
@export var show_debug: bool = true

@onready var rooms_container: Node3D = $RoomsContainer
@onready var caps_container: Node3D = $CapsContainer
@onready var entities_container: Node3D = $EntitiesContainer

var _generated: bool = false


func _ready() -> void:
	if auto_generate:
		call_deferred(\"generate_dungeon\")


func _input(event: InputEvent) -> void:
	if event.is_action_pressed(\"ui_accept\"):
		# Regenerate with new seed
		test_seed = randi()
		_clear_dungeon()
		generate_dungeon()
	elif event.is_action_pressed(\"ui_cancel\"):
		# Run stress test
		_run_stress_test()


func generate_dungeon() -> void:
	if _generated:
		_clear_dungeon()

	print(\"Generating dungeon with seed %d...\" % test_seed)

	# Get DungeonManager (create locally if not autoload)
	var manager: Node = _get_or_create_manager()

	manager.debug_draw_enabled = show_debug

	var success: bool = manager.generate_and_populate(
		\"test_dungeon\",
		test_seed,
		rooms_container,
		caps_container,
		entities_container,
		max_rooms
	)

	if success:
		print(\"Dungeon generated successfully!\")
		manager.print_dungeon()
		_generated = true
	else:
		print(\"Dungeon generation failed!\")


func _clear_dungeon() -> void:
	for child in rooms_container.get_children():
		child.queue_free()
	for child in caps_container.get_children():
		child.queue_free()
	for child in entities_container.get_children():
		child.queue_free()

	var manager: Node = _get_or_create_manager()
	manager.clear_debug_draw()

	_generated = false


func _run_stress_test() -> void:
	print(\"Running stress test...\")
	var manager: Node = _get_or_create_manager()
	manager.run_stress_test(100, false)


func _get_or_create_manager() -> Node:
	if has_node(\"/root/DungeonManager\"):
		return get_node(\"/root/DungeonManager\")

	# Create local instance
	var manager_script: GDScript = load(\"res://scripts/dungeons/dungeon_manager.gd\")
	var manager: Node = Node.new()
	manager.set_script(manager_script)
	manager.name = \"LocalDungeonManager\"
	add_child(manager)
	return manager
"

[node name="DungeonTestScene" type="Node3D"]
script = SubResource("GDScript_test")

[node name="Camera3D" type="Camera3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 0.707107, 0.707107, 0, -0.707107, 0.707107, 40, 60, 40)
fov = 60.0

[node name="DirectionalLight3D" type="DirectionalLight3D" parent="."]
transform = Transform3D(0.866, -0.25, 0.433, 0, 0.866, 0.5, -0.5, -0.433, 0.75, 0, 20, 0)
light_energy = 0.8
shadow_enabled = true

[node name="WorldEnvironment" type="WorldEnvironment" parent="."]

[node name="RoomsContainer" type="Node3D" parent="."]

[node name="CapsContainer" type="Node3D" parent="."]

[node name="EntitiesContainer" type="Node3D" parent="."]

[node name="UI" type="Control" parent="."]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="Label" type="Label" parent="UI"]
layout_mode = 1
anchors_preset = 1
anchor_left = 1.0
anchor_right = 1.0
offset_left = -250.0
offset_bottom = 80.0
grow_horizontal = 0
text = "Press ENTER to regenerate
Press ESC for stress test"
