script = ExtResource("1")
id = "lore_elves"
display_name = "The Forest Kingdoms"
description = "A rare collection of knowledge about the reclusive elven civilization. Documents both the diplomatic faction that engages with humans and the isolationists who would see all outsiders driven from their lands. Handle with discretion near elven territories."
