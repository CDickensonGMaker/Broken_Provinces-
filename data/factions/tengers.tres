[resource]
script = ExtResource("1")
id = "tengers"
display_name = "Tenger Horde"
description = "A fierce human subgroup from the southern wastes known for their brutal warrior culture. The Tengers are blood-thirsty marauders who have razed villages like Windmere and Dusty Hollow. They despise magic and follow clan warlords who rule through strength alone. Their camps are marked by war banners and skull totems."
