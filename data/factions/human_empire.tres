alignment = 20
ranks = [{"name": "Outlaw", "min_reputation": -100, "benefits": []}, {"name": "Stranger", "min_reputation": -50, "benefits": []}, {"name": "Citizen", "min_reputation": 0, "benefits": ["legal_protection"]}, {"name": "Respected", "min_reputation": 30, "benefits": ["legal_protection", "reduced_taxes"]}, {"name": "Honored", "min_reputation": 60, "benefits": ["legal_protection", "reduced_taxes", "noble_access"]}, {"name": "Champion", "min_reputation": 90, "benefits": ["legal_protection", "reduced_taxes", "noble_access", "royal_favor"]}]
default_reputation = 0
joinable = false
