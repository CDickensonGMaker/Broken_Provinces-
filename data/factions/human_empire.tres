[resource]
script = ExtResource("1")
id = "human_empire"
display_name = "Human Empire"
description = "The dominant political power in the known world, ruled from the Imperial Capital. The Empire controls trade, maintains roads, and enforces law throughout human lands. Unknown to most, the current ruler is an imposter - a witch who has secretly replaced the true King."
parent_faction = ""
allies = ["the_crown", "imperial_army", "church_of_three"]
enemies = ["goblins", "undead", "thieves_guild"]
