[resource]
script = ExtResource("1")
id = "church_of_three"
display_name = "Church of Three Gods"
description = "The dominant religious institution of the Human Empire, worshipping the trinity of Time (Chronos), Harvest (Gaela), and Death & Rebirth (Morthane). Priests of the Three provide blessings, healing, and spiritual guidance throughout the realm. The Church maintains temples in every significant settlement."
parent_faction = "human_empire"
allies = ["human_empire", "town_guard"]
enemies = ["undead", "cultists"]
neutrals = ["dwarves", "elves_pro_human", "thieves_guild"]
alignment = 60
ranks = [{"name": "Heretic", "min_reputation": -100, "benefits": []}, {"name": "Sinner", "min_reputation": -50, "benefits": []}, {"name": "Penitent", "min_reputation": -20, "benefits": []}, {"name": "Faithful", "min_reputation": 0, "benefits": ["blessing_access"]}, {"name": "Devout", "min_reputation": 30, "benefits": ["blessing_access", "healing_discount"]}, {"name": "Blessed", "min_reputation": 60, "benefits": ["blessing_access", "healing_discount", "temple_sanctuary"]}, {"name": "Champion of the Three", "min_reputation": 85, "benefits": ["blessing_access", "healing_discount", "temple_sanctuary", "holy_quests"]}]
default_reputation = 10
joinable = false
join_threshold = 30
is_hidden = false
faction_color = Color(0.9, 0.85, 0.6, 1.0)
