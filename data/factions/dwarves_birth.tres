[resource]
script = ExtResource("1")
id = "dwarves_birth"
display_name = "Dwarves of Birth"
description = "The traditionalist faction of dwarven society, valuing lineage, hereditary rule, and ancient customs. They believe leadership should pass through bloodlines and that the old ways are the true ways. They are suspicious of innovation and outsiders who might dilute their culture."
