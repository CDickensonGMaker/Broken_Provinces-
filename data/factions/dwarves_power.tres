[resource]
script = ExtResource("1")
id = "dwarves_power"
display_name = "Dwarves of Power"
description = "The progressive faction of dwarven society, valuing achievement, meritocracy, and innovation. They believe leadership should be earned through deeds and skill, not birthright. They are more open to trade with outsiders and adopting new techniques."
