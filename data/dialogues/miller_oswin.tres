script = ExtResource("1_data")
id = "miller_oswin"
display_name = "Miller Oswin Dialogue"
description = "Dialogue for Miller Oswin, the worried miller of Millbrook whose watermill has mysteriously stopped working. Quest giver for the watermill curse investigation."
start_node_id = "start"
nodes = [SubResource("node_start"), SubResource("node_mill_problem"), SubResource("node_lake_lore"), SubResource("node_fishing_trouble"), SubResource("node_ask_help"), SubResource("node_quest_accepted"), SubResource("node_quest_declined"), SubResource("node_end")]
