description = "Dialogue for Elder Willa, leader of Millbrook village. Quest giver for the bandit extermination quest and source of information about the village's troubles."
start_node_id = "start"
nodes = [SubResource("node_start"), SubResource("node_bandit_trouble"), SubResource("node_about_millbrook"), SubResource("node_about_lake"), SubResource("node_work_available"), SubResource("node_quest_accepted"), SubResource("node_quest_declined"), SubResource("node_end")]
